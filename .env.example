# ===== REQUIRED: DOMAIN & SSL =====
# Your domain name (without www)
DOMAIN=example.com
# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@example.com

# ===== REQUIRED: DATABASE =====
# MySQL root password (use a strong, random password)
MYSQL_ROOT_PASSWORD=change_me_to_strong_password_12345
# Database name
MYSQL_DATABASE=nazariy
# Database user
MYSQL_USER=nazariy_user
# Database user password (use a strong, random password)
MYSQL_PASSWORD=change_me_to_strong_password_67890

# ===== REQUIRED: BACKEND =====
# Node environment (production)
NODE_ENV=production
# Backend API port
PORT=4000
# Database connection details (docker service name)
DB_HOST=mysql
DB_PORT=3306
DB_POOL_SIZE=10
# JWT secret for authentication (generate a strong random string, min 32 chars)
JWT_SECRET=generate_a_strong_random_secret_key_minimum_32_characters_long
# Telegram bot configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
SUPER_ADMIN_TG_ID=123456789

# ===== FRONTEND =====
# API URL for frontend
VITE_API_URL=https://example.com/api
