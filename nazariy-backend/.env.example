# ═══════════════════════════════════════════════════════════════
# NAZARIY BACKEND — .env (PRODUCTION)
# ═══════════════════════════════════════════════════════════════

# ─── Server ───
PORT=4000
NODE_ENV=production

# ─── JWT Secret ───
# 32+ belgili tasodifiy satr! Generatsiya:
# openssl rand -hex 32
# EXAMPLE: a3f9d2c1b8e4f7a2d9c5b1e8f3a6d2c9
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32_PLUS_CHARS

# ─── Telegram Bot ───
# @BotFather dan olinadi
# EXAMPLE: 123456789:ABCDEfghIjklMnoPqrStUvWxYz-1234567
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ─── Database (MySQL / PostgreSQL) ───
# Beget, PlanetScale, AWS RDS, yoki boshqa managed service
# EXAMPLE MySQL: mysql://user:pass@host:3306/dbname
# EXAMPLE PlanetScale: mysql://user:pass@host.us-west-2.db.planetscale.com/dbname?ssl={"rejectUnauthorized":true}
DB_HOST=your-database-host.com
DB_PORT=3306
DB_USER=database_user
DB_PASSWORD=strong_database_password
DB_NAME=nazariy_db
DB_POOL_SIZE=5

# ─── CORS ───
# Production'da faqat o'z domeningiz!
# EXAMPLE: https://app.nazariy.uz
FRONTEND_ORIGIN=https://your-web-domain.com

# ─── Admin ───
# Birinchi marta login qilganda super admin bo'ladi
# EXAMPLE: 123456789
SUPER_ADMIN_TG_ID=YOUR_TELEGRAM_ID
